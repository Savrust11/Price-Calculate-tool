# ============================================================
# Yahoo Auction Price Calculator — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env
#
# All values below show their defaults. Uncomment and change
# only the ones you want to override.
# ============================================================

# --- Fees & Margins -----------------------------------------
# MARKETPLACE_FEE=0.10
# CONSUMPTION_TAX=0.10
# PROFIT_MARGIN=0.50

# --- Market Price Calculation --------------------------------
# MARKET_PRICE_METHOD=median        # median | average | trimmed_mean
# TRIMMED_MEAN_TRIM=0.10
# MIN_LISTINGS=1

# --- Scraper Settings ----------------------------------------
# MAX_PAGES_PER_PRODUCT=2
# MAX_LISTINGS_PER_PRODUCT=25

# --- Flask / Web App ----------------------------------------
# FLASK_PORT=5001
# FLASK_DEBUG=false
# UPLOAD_FOLDER=uploads
# OUTPUT_FOLDER=outputs
# MAX_UPLOAD_MB=16
